<div class="p-4 rounded-2xl border backdrop-blur-md shadow-lg dark:shadow-2xl flex items-start gap-3 pointer-events-auto transition-all duration-300 animate-slide-in <%= type == 'notice' ? 'bg-emerald-50/90 dark:bg-emerald-950/70 border-emerald-200 dark:border-emerald-800/80 text-emerald-800 dark:text-emerald-200' : 'bg-rose-50/90 dark:bg-rose-950/70 border-rose-200 dark:border-rose-800/80 text-rose-800 dark:text-rose-200' %>" 
     role="alert"
     data-controller="flash-dismiss"
     data-flash-dismiss-delay-value="5000">
  <span class="shrink-0 mt-0.5">
    <% if type == 'notice' %>
      <i data-lucide="check-circle-2" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    <% else %>
      <i data-lucide="alert-triangle" class="w-5 h-5 text-rose-600 dark:text-rose-400"></i>
    <% end %>
  </span>
  <div class="flex-grow text-sm font-medium pr-2 leading-relaxed">
    <%= message %>
  </div>
  <button data-action="click->flash-dismiss#dismiss" class="shrink-0 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 p-0.5 rounded-lg hover:bg-slate-200/50 dark:hover:bg-slate-800/50 transition duration-150 cursor-pointer flex items-center justify-center" aria-label="Close notification">
    <i data-lucide="x" class="w-4 h-4"></i>
  </button>
</div>
