<!DOCTYPE html>
<html>
  <head>
    <!-- Theme setup script to prevent flash of light/dark theme -->
    <script>
      (function() {
        const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <title><%= content_for(:title) || "Horizon Weather" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Horizon Weather">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg?v=2" type="image/svg+xml">
    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png?v=2">

    <!-- Leaflet.js Map CDN -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-slate-100 min-h-screen flex flex-col font-sans selection:bg-cyan-500 selection:text-slate-900 transition-colors duration-300"
        data-controller="app-start-location"
        data-user-logged-in="<%= authenticated? %>"
        data-user-id="<%= Current.user&.id %>">
    <!-- Top Navigation Bar -->
    <header class="border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md sticky top-0 z-50 transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <a href="<%= root_path %>" class="flex items-center gap-2 font-bold text-xl text-transparent bg-clip-text bg-gradient-to-r from-cyan-600 to-blue-600 dark:from-cyan-400 dark:to-blue-500 hover:opacity-90 transition">
            <i data-lucide="cloud-sun" class="w-6 h-6 text-cyan-500 dark:text-cyan-400"></i>
            <span>Horizon Weather</span>
          </a>

          <!-- Navigation Links -->
          <nav class="hidden sm:flex items-center gap-6 text-sm font-semibold ml-2">
            <a href="<%= root_path %>" class="text-slate-600 dark:text-slate-300 hover:text-cyan-600 dark:hover:text-cyan-400 transition flex items-center gap-1.5 py-1 border-b-2 border-transparent hover:border-cyan-500">
              <i data-lucide="cloud" class="w-4 h-4"></i>
              <span>Weather</span>
            </a>
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <!-- Theme Toggle Button -->
          <div data-controller="theme" class="flex items-center">
            <button data-action="click->theme#toggle" class="p-2 rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800/60 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700/60 text-slate-700 dark:text-slate-300 hover:text-cyan-600 dark:hover:text-cyan-400 transition cursor-pointer flex items-center justify-center" title="Toggle Light/Dark Theme">
              <i data-theme-target="lightIcon" class="w-4.5 h-4.5 hidden" data-lucide="sun"></i>
              <i data-theme-target="darkIcon" class="w-4.5 h-4.5 hidden" data-lucide="moon"></i>
            </button>
          </div>

          <!-- Unit Toggle Button -->
          <div class="flex items-center rounded-xl bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700/60 p-0.5 text-[11px] font-bold">
            <%= button_to unit_path, method: :patch, params: { unit_system: "imperial" }, form_class: "inline-flex", class: "px-2.5 py-1 rounded-lg transition-all cursor-pointer #{unit_system == 'imperial' ? 'bg-white dark:bg-slate-700 text-cyan-600 dark:text-cyan-400 shadow-sm font-extrabold' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200'}" do %>
              °F
            <% end %>
            <%= button_to unit_path, method: :patch, params: { unit_system: "metric" }, form_class: "inline-flex", class: "px-2.5 py-1 rounded-lg transition-all cursor-pointer #{unit_system == 'metric' ? 'bg-white dark:bg-slate-700 text-cyan-600 dark:text-cyan-400 shadow-sm font-extrabold' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200'}" do %>
              °C
            <% end %>
          </div>

          <!-- Authentication Controls -->
          <nav class="flex items-center gap-4 text-sm font-medium">
            <% if authenticated? %>
              <span class="hidden md:inline text-slate-500 dark:text-slate-400">Signed in as <strong class="text-slate-700 dark:text-slate-200"><%= Current.user.email_address %></strong></span>
              <%= button_to session_path, method: :delete, class: "px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-750 hover:text-slate-900 dark:hover:text-white transition cursor-pointer" do %>
                Log Out
              <% end %>
            <% else %>
              <a href="<%= new_session_path %>" class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition font-semibold font-sans">Log In</a>
              <a href="<%= signup_path %>" class="px-3 py-1.5 rounded-lg bg-cyan-600 hover:bg-cyan-500 text-white shadow-md shadow-cyan-900/10 dark:shadow-cyan-900/20 transition font-semibold font-sans">Sign Up</a>
            <% end %>
          </nav>
        </div>
      </div>
    </header>

    <!-- Flash Notifications (Toast Container) -->
    <div id="flash_container" class="fixed top-20 right-4 sm:right-6 z-[100] flex flex-col gap-3 max-w-md w-[calc(100vw-2rem)] sm:w-96 pointer-events-none">
      <% if flash.any? %>
        <% flash.each do |type, message| %>
          <%= render "layouts/flash", type: type, message: message %>
        <% end %>
      <% end %>
    </div>

    <!-- Main Content Area -->
    <main class="<%= content_for?(:main_class) ? yield(:main_class) : "flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full" %>">
      <%= yield %>
    </main>

    <% unless content_for?(:hide_footer) %>
      <footer class="border-t border-slate-200 dark:border-slate-800 bg-slate-100/50 dark:bg-slate-950/40 py-6 mt-12 text-center text-xs text-slate-500 transition-colors duration-300">
        <p>&copy; <%= Time.current.year %> Horizon Weather. Powered by Open-Meteo & Leaflet.</p>
      </footer>
    <% end %>

    <!-- Initialize Lucide Icons -->
    <script>
      function initLucide() {
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
      }
      document.addEventListener("turbo:load", initLucide);
      document.addEventListener("turbo:render", initLucide);
      document.addEventListener("turbo:frame-load", initLucide);
      document.addEventListener("turbo:before-stream-render", function(event) {
        const originalRender = event.detail.render;
        event.detail.render = function(streamElement) {
          originalRender(streamElement);
          initLucide();
        };
      });
    </script>
  </body>
</html>
