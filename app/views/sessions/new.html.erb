<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>

<div class="max-w-md mx-auto my-12 p-8 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/60 backdrop-blur-md shadow-lg dark:shadow-xl transition-colors duration-300">
  <div class="text-center mb-8">
    <i data-lucide="lock" class="w-12 h-12 text-cyan-600 dark:text-cyan-400 mx-auto mb-3"></i>
    <h1 class="font-bold text-3xl text-slate-900 dark:text-white">Welcome Back</h1>
    <p class="text-slate-500 dark:text-slate-400 text-sm mt-2">Sign in to manage your favorite weather locations</p>
  </div>

  <%= form_with url: session_url, class: "space-y-6" do |form| %>
    <div>
      <%= form.label :email_address, "Email Address", class: "block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com", value: params[:email_address], class: "block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800 px-4 py-3 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition" %>
    </div>

    <div>
      <div class="flex items-center justify-between mb-2">
        <%= form.label :password, "Password", class: "block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400" %>
        <%= link_to "Forgot?", new_password_path, class: "text-xs text-cyan-600 dark:text-cyan-400 hover:underline" %>
      </div>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "••••••••", maxlength: 72, class: "block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800 px-4 py-3 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition" %>
    </div>

    <div>
      <%= form.submit "Sign In", class: "w-full py-3 px-4 rounded-xl bg-gradient-to-r from-cyan-600 to-blue-600 dark:from-cyan-500 dark:to-blue-600 hover:from-cyan-700 hover:to-blue-700 text-white font-semibold cursor-pointer shadow-md dark:shadow-lg shadow-cyan-900/10 dark:shadow-cyan-900/30 transition active:scale-[0.98]" %>
    </div>

    <div class="text-center text-sm text-slate-500 dark:text-slate-400 mt-6">
      Don't have an account? 
      <%= link_to "Sign up now", signup_path, class: "text-cyan-600 dark:text-cyan-400 hover:underline font-medium" %>
    </div>
  <% end %>
</div>
