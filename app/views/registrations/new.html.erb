<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>

<div class="max-w-md mx-auto my-12 p-8 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/60 backdrop-blur-md shadow-lg dark:shadow-xl transition-colors duration-300">
  <div class="text-center mb-8">
    <i data-lucide="user-plus" class="w-12 h-12 text-cyan-600 dark:text-cyan-400 mx-auto mb-3"></i>
    <h1 class="font-bold text-3xl text-slate-900 dark:text-white">Create Account</h1>
    <p class="text-slate-555 dark:text-slate-400 text-sm mt-2">Sign up to customize your weather dashboard</p>
  </div>

  <%= form_with model: @user, url: signup_path, class: "space-y-6" do |form| %>
    <% if @user.errors.any? %>
      <div class="p-4 rounded-xl border border-rose-200 dark:border-rose-800 bg-rose-50/50 dark:bg-rose-950/40 text-rose-800 dark:text-rose-300 text-sm">
        <p class="font-bold mb-1">Please correct the following errors:</p>
        <ul class="list-disc pl-5 space-y-1">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email_address, "Email Address", class: "block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2" %>
      <%= form.email_field :email_address, required: true, autofocus: true, placeholder: "you@example.com", class: "block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-850 px-4 py-3 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition" %>
    </div>

    <div>
      <%= form.label :password, "Password", class: "block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2" %>
      <%= form.password_field :password, required: true, placeholder: "At least 6 characters", class: "block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-850 px-4 py-3 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm Password", class: "block text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2" %>
      <%= form.password_field :password_confirmation, required: true, placeholder: "••••••••", class: "block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-850 px-4 py-3 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-550 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition" %>
    </div>

    <div>
      <%= form.submit "Create Account", class: "w-full py-3 px-4 rounded-xl bg-gradient-to-r from-cyan-600 to-blue-600 dark:from-cyan-500 dark:to-blue-600 hover:from-cyan-555 hover:to-blue-555 text-white font-semibold cursor-pointer shadow-md dark:shadow-lg shadow-cyan-900/10 dark:shadow-cyan-900/30 transition active:scale-[0.98]" %>
    </div>

    <div class="text-center text-sm text-slate-550 dark:text-slate-400 mt-6">
      Already have an account? 
      <%= link_to "Log in instead", new_session_path, class: "text-cyan-600 dark:text-cyan-400 hover:underline font-medium" %>
    </div>
  <% end %>
</div>
