<!-- Last updated badge & Favorite button -->
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div class="flex flex-col gap-1">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white"><%= @location_name %></h1>
      
      <%= render "weather/favorite_header_button" %>
    </div>
    
    <% if @local_time %>
      <div class="flex items-center flex-wrap gap-x-2 gap-y-1 select-none">
        <div class="flex items-center gap-1 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
          <i data-lucide="clock" class="w-3.5 h-3.5 text-cyan-600 dark:text-cyan-400 animate-pulse shrink-0"></i>
          <span>Local Time:</span>
        </div>
        <span class="text-xs text-slate-500 dark:text-slate-400"><%= @local_time.strftime("%A, %b %-d,") %></span>
        <strong class="text-xl font-extrabold text-slate-900 dark:text-white leading-none tracking-tight"><%= @local_time.strftime("%I:%M %p") %></strong>
        <span class="text-[10px] font-bold text-cyan-600 dark:text-cyan-500/80 uppercase"><%= @weather["timezone_abbreviation"] %></span>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100/80 dark:bg-slate-900/80 border border-slate-200 dark:border-slate-800 text-xs text-slate-600 dark:text-slate-400 transition-colors duration-300">
    <% if @weather["is_fallback"] %>
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
      </span>
      <span class="text-amber-600 dark:text-amber-400 font-semibold">Offline Mode (Demo Data)</span>
    <% else %>
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 dark:bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span>Auto-updating forecast</span>
    <% end %>
    <span class="text-slate-300 dark:text-slate-700">|</span>
    <span>Updated <span data-controller="local-time" data-local-time-utc-value="<%= Time.current.iso8601 %>" class="font-semibold"><%= Time.current.strftime("%I:%M:%S %p") %></span></span>
  </div>
</div>
