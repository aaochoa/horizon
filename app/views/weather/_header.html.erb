<!-- Last updated badge & Favorite button -->
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div class="flex flex-col gap-1">
    <div class="flex items-center gap-3">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white"><%= @location_name %></h1>
      
      <% if authenticated? %>
        <% if @is_favorited %>
          <% favorite = @favorites.find { |f| (f.latitude - @latitude.to_f).abs < 0.001 && (f.longitude - @longitude.to_f).abs < 0.001 } %>
          <%= button_to favorite_location_path(favorite, lat: @latitude, lon: @longitude, name: @location_name), method: :delete, class: "p-2 rounded-xl bg-rose-50 dark:bg-rose-950/40 hover:bg-rose-100 dark:hover:bg-rose-900/40 border border-rose-200 dark:border-rose-800/60 hover:border-rose-300 dark:hover:border-rose-600/60 text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 transition cursor-pointer flex items-center justify-center", title: "Remove from favorites" do %>
            <i data-lucide="heart" class="w-5 h-5 fill-current"></i>
          <% end %>
        <% else %>
          <%= form_with model: FavoriteLocation.new, url: favorite_locations_path, class: "inline" do |form| %>
            <%= form.hidden_field :name, value: @location_name %>
            <%= form.hidden_field :latitude, value: @latitude %>
            <%= form.hidden_field :longitude, value: @longitude %>
            <%= form.button type: :submit, class: "p-2 rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800/40 dark:hover:bg-slate-700/40 border border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-500 text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300 transition cursor-pointer flex items-center justify-center", title: "Add to favorites" do %>
              <i data-lucide="heart" class="w-5 h-5"></i>
            <% end %>
          <% end %>
        <% end %>
      <% else %>
        <a href="<%= new_session_path %>" data-turbo-frame="_top" class="p-2 rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800/40 dark:hover:bg-slate-700/40 border border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-500 text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-400 transition flex items-center justify-center" title="Log in to favorite this location">
          <i data-lucide="heart" class="w-5 h-5"></i>
        </a>
      <% end %>
    </div>
    
    <% if @local_time %>
      <div class="flex items-center flex-wrap gap-x-2 gap-y-1 select-none">
        <div class="flex items-center gap-1 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
          <i data-lucide="clock" class="w-3.5 h-3.5 text-cyan-600 dark:text-cyan-400 animate-pulse shrink-0"></i>
          <span>Local Time:</span>
        </div>
        <span class="text-xs text-slate-500 dark:text-slate-400"><%= @local_time.strftime("%A, %b %-d,") %></span>
        <strong class="text-xl font-extrabold text-slate-900 dark:text-white leading-none tracking-tight"><%= @local_time.strftime("%I:%M %p") %></strong>
        <span class="text-[10px] font-bold text-cyan-600 dark:text-cyan-500/80 uppercase"><%= @weather["timezone_abbreviation"] %></span>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100/80 dark:bg-slate-900/80 border border-slate-200 dark:border-slate-800 text-sm text-slate-600 dark:text-slate-400 transition-colors duration-300">
    <% if @weather["is_fallback"] %>
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
      </span>
      <span class="text-amber-600 dark:text-amber-400 font-semibold">Offline Mode (Demo Data)</span>
    <% else %>
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 dark:bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span>Auto-updating forecast</span>
    <% end %>
    <span class="text-slate-300 dark:text-slate-700">|</span>
    <span>Updated <span data-controller="local-time" data-local-time-utc-value="<%= Time.current.iso8601 %>" class="font-semibold"><%= Time.current.strftime("%H:%M:%S") %></span></span>
  </div>
</div>
