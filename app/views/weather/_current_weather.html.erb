<!-- Hero Forecast Card -->
<div class="relative overflow-hidden rounded-3xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/40 backdrop-blur-md p-8 shadow-lg dark:shadow-xl flex flex-col md:flex-row justify-between items-center gap-6 transition-colors duration-300">
  <!-- Background glow -->
  <div class="absolute -right-12 -bottom-12 w-48 h-48 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="space-y-4 text-center md:text-left">
    <div>
      <p class="text-slate-500 dark:text-slate-400 text-sm font-semibold uppercase tracking-wider">Current Weather</p>
      <h2 class="text-6xl font-black text-slate-900 dark:text-white mt-1">
        <%= current["temperature_2m"].round %>°C
      </h2>
      <p class="text-xl font-bold text-cyan-600 dark:text-cyan-400 mt-1"><%= current_info[:description] %></p>
    </div>
    
    <div class="grid grid-cols-2 gap-4 text-xs">
      <div class="flex items-center gap-2 text-slate-600 dark:text-slate-300">
        <i data-lucide="thermometer" class="w-4 h-4 text-cyan-555 dark:text-cyan-400"></i>
        <span>Feels like <strong><%= current["apparent_temperature"].round %>°C</strong></span>
      </div>
      <div class="flex items-center gap-2 text-slate-600 dark:text-slate-300">
        <i data-lucide="droplets" class="w-4 h-4 text-cyan-555 dark:text-cyan-400"></i>
        <span>Humidity <strong><%= current["relative_humidity_2m"] %>%</strong></span>
      </div>
      <div class="flex items-center gap-2 text-slate-600 dark:text-slate-300">
        <i data-lucide="wind" class="w-4 h-4 text-cyan-555 dark:text-cyan-400"></i>
        <span>Wind <strong><%= current["wind_speed_10m"].round %> km/h</strong></span>
      </div>
      <div class="flex items-center gap-2 text-slate-600 dark:text-slate-300">
        <i data-lucide="cloud-rain" class="w-4 h-4 text-cyan-555 dark:text-cyan-400"></i>
        <span>Precip. <strong><%= current["precipitation"] %> mm</strong></span>
      </div>
    </div>
  </div>

  <div class="flex flex-col items-center md:items-end justify-center">
    <i data-lucide="<%= current_info[:icon] %>" class="w-36 h-36 text-gradient from-cyan-500 to-blue-600 dark:from-cyan-400 dark:to-blue-500 stroke-[1.2]"></i>
  </div>
</div>
