<!-- Favorites Card -->
<% if authenticated? %>
  <details id="favorites" class="group rounded-3xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/40 backdrop-blur-md p-6 shadow-lg dark:shadow-xl transition-colors duration-300 [&_summary::-webkit-details-marker]:hidden">
    <summary class="flex items-center justify-between cursor-pointer focus:outline-none list-none select-none">
      <h3 class="font-bold text-lg text-slate-900 dark:text-white flex items-center gap-2">
        <i data-lucide="heart" class="w-5 h-5 text-rose-500 fill-rose-500/20"></i>
        <span>Saved Locations</span>
      </h3>
      <div class="text-slate-400 dark:text-slate-500 transition-transform duration-300 group-open:rotate-180">
        <i data-lucide="chevron-down" class="w-5 h-5"></i>
      </div>
    </summary>

    <div class="mt-4 space-y-4">
      <% if @favorites.any? %>
        <div class="space-y-2">
          <% @favorites.each do |fav| %>
            <div class="flex items-center justify-between gap-2 p-3 rounded-2xl bg-slate-100/50 dark:bg-slate-950/30 border border-slate-200/60 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-800 transition">
              <a href="<%= root_path(lat: fav.latitude, lon: fav.longitude, name: fav.name) %>" data-turbo-frame="_top" class="text-sm font-semibold text-slate-700 dark:text-slate-200 hover:text-cyan-600 dark:hover:text-cyan-400 transition truncate block w-full">
                <%= fav.name %>
              </a>
              
              <div class="flex items-center gap-1 shrink-0">
                <span class="text-xs text-slate-400 dark:text-slate-500 pr-1 font-mono text-right shrink-0">
                  <%= fav.latitude.round(2) %>, <%= fav.longitude.round(2) %>
                </span>
                <%= button_to favorite_location_path(fav, lat: @latitude, lon: @longitude, name: @location_name), method: :delete, class: "text-slate-400 dark:text-slate-500 hover:text-rose-500 transition cursor-pointer" do %>
                  <i data-lucide="trash" class="w-4 h-4"></i>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-6 text-center rounded-2xl border border-dashed border-slate-200 dark:border-slate-800 text-slate-400 dark:text-slate-500 text-sm">
          <i data-lucide="map" class="w-8 h-8 mx-auto mb-2 text-slate-300 dark:text-slate-600"></i>
          <p>No saved locations yet</p>
          <p class="text-xs text-slate-500 dark:text-slate-600 mt-1">Click the heart button above to save a city.</p>
        </div>
      <% end %>
    </div>
  </details>
<% else %>
  <div id="favorites" class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/40 backdrop-blur-md p-6 shadow-lg dark:shadow-xl text-center space-y-3 transition-colors duration-300">
    <i data-lucide="user" class="w-10 h-10 text-cyan-600 dark:text-cyan-500/80 mx-auto"></i>
    <h4 class="font-bold text-slate-900 dark:text-white text-md">Save Your Favorites</h4>
    <p class="text-xs text-slate-500 dark:text-slate-400">Log in or sign up to save your favorite cities for quick weather checking!</p>
    <div class="flex gap-2 justify-center pt-2">
      <a href="<%= new_session_path %>" data-turbo-frame="_top" class="px-4 py-2 rounded-xl bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-xs font-semibold text-slate-700 dark:text-slate-200 hover:bg-slate-200 dark:hover:bg-slate-700 transition">Log In</a>
      <a href="<%= signup_path %>" data-turbo-frame="_top" class="px-4 py-2 rounded-xl bg-cyan-600 text-xs font-semibold text-white hover:bg-cyan-500 transition">Sign Up</a>
    </div>
  </div>
<% end %>
