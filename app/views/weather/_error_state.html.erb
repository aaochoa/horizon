<!-- Weather Service Error State -->
<div class="p-12 text-center rounded-3xl border border-slate-800 bg-slate-900/40 backdrop-blur-md">
  <i data-lucide="cloud-off" class="w-16 h-16 text-rose-500 mx-auto mb-4"></i>
  <h2 class="text-2xl font-bold text-white">Weather Data Unavailable</h2>
  <p class="text-slate-400 mt-2 max-w-md mx-auto">We couldn't retrieve forecast information. The Open-Meteo service might be temporarily offline or the coordinates might be invalid.</p>
  <a href="<%= root_path %>" class="mt-6 inline-block px-5 py-3 rounded-2xl bg-cyan-600 hover:bg-cyan-500 text-white font-semibold shadow-lg shadow-cyan-900/20 transition">
    Try Again
  </a>
</div>
