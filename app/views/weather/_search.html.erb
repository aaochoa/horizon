<!-- Autocomplete Search & Geolocation bar -->
<div class="relative w-full" data-controller="autocomplete">
  <div class="relative w-full">
    <form class="relative flex items-center" data-autocomplete-target="form" onsubmit="event.preventDefault()">
      <span class="absolute left-4 text-slate-400 dark:text-slate-500">
        <i data-lucide="search" class="w-5 h-5"></i>
      </span>
      <input type="text"
             placeholder="Search for cities..."
             class="w-full bg-white/90 dark:bg-slate-900/90 backdrop-blur border border-slate-200 dark:border-slate-800 rounded-2xl pl-12 pr-12 py-3.5 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition shadow-md dark:shadow-lg"
             data-autocomplete-target="input"
             data-action="input->autocomplete#onInput">
      <button type="button"
              class="absolute right-3 p-2 rounded-xl text-slate-400 hover:text-cyan-600 dark:text-slate-500 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800/80 transition cursor-pointer flex items-center justify-center"
              title="Use current location"
              data-action="click->autocomplete#useCurrentLocation">
        <i data-lucide="map-pin" class="w-4.5 h-4.5"></i>
      </button>
    </form>
    <!-- Results Dropdown -->
    <div class="absolute w-full mt-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-xl dark:shadow-2xl hidden z-[100] overflow-hidden"
         data-autocomplete-target="results">
    </div>
  </div>
</div>
