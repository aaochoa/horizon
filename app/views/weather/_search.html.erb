<!-- Autocomplete Search & Geolocation bar -->
<div class="mb-8" data-controller="autocomplete">
  <div class="flex flex-col md:flex-row gap-4 items-center justify-between w-full relative">
    <div class="relative w-full md:max-w-xl">
      <form class="relative flex items-center" data-autocomplete-target="form" onsubmit="event.preventDefault()">
        <span class="absolute left-4 text-slate-400 dark:text-slate-500">
          <i data-lucide="search" class="w-5 h-5"></i>
        </span>
        <input type="text"
               placeholder="Search for cities..."
               class="w-full bg-white/70 dark:bg-slate-900/60 backdrop-blur border border-slate-200 dark:border-slate-800 rounded-2xl pl-12 pr-4 py-3 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition shadow-md dark:shadow-lg"
               data-autocomplete-target="input"
               data-action="input->autocomplete#onInput">
      </form>
      <!-- Results Dropdown -->
      <div class="absolute w-full mt-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-xl dark:shadow-2xl hidden z-50 overflow-hidden"
           data-autocomplete-target="results">
      </div>
    </div>

    <button type="button"
            class="w-full md:w-auto px-5 py-3 rounded-2xl bg-cyan-50/50 dark:bg-cyan-950/40 border border-cyan-200 dark:border-cyan-800/40 hover:bg-cyan-100/50 dark:hover:bg-cyan-900/40 hover:border-cyan-300 dark:hover:border-cyan-600/40 text-cyan-700 dark:text-cyan-300 font-semibold shadow-md dark:shadow-lg shadow-cyan-900/5 dark:shadow-cyan-950/20 transition flex items-center justify-center gap-2 cursor-pointer"
            data-action="click->autocomplete#useCurrentLocation">
      <i data-lucide="map-pin" class="w-4 h-4"></i>
      <span>Use Current Location</span>
    </button>
  </div>
</div>
