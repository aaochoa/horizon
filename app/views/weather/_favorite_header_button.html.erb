<div id="favorite_header_button" class="inline flex items-center">
  <% if authenticated? %>
    <% if @is_favorited %>
      <% favorite = @favorites.find { |f| (f.latitude - @latitude.to_f).abs < 0.001 && (f.longitude - @longitude.to_f).abs < 0.001 } %>
      <%= button_to favorite_location_path(favorite, lat: @latitude, lon: @longitude, name: @location_name), method: :delete, class: "p-2 rounded-xl bg-rose-50 dark:bg-rose-950/40 hover:bg-rose-100 dark:hover:bg-rose-900/40 border border-rose-200 dark:border-rose-800/60 hover:border-rose-300 dark:hover:border-rose-600/60 text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 transition cursor-pointer flex items-center justify-center", title: "Remove from favorites" do %>
        <i data-lucide="heart" class="w-5 h-5 fill-current"></i>
      <% end %>
    <% else %>
      <%= form_with model: FavoriteLocation.new, url: favorite_locations_path, class: "inline" do |form| %>
        <%= form.hidden_field :name, value: @location_name %>
        <%= form.hidden_field :latitude, value: @latitude %>
        <%= form.hidden_field :longitude, value: @longitude %>
        <%= form.button type: :submit, class: "p-2 rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800/40 dark:hover:bg-slate-700/40 border border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-500 text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300 transition cursor-pointer flex items-center justify-center", title: "Add to favorites" do %>
          <i data-lucide="heart" class="w-5 h-5"></i>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <a href="<%= new_session_path %>" data-turbo-frame="_top" class="p-2 rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800/40 dark:hover:bg-slate-700/40 border border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-500 text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-400 transition flex items-center justify-center" title="Log in to favorite this location">
      <i data-lucide="heart" class="w-5 h-5"></i>
    </a>
  <% end %>
</div>
