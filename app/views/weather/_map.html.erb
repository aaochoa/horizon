<!-- Interactive Map Canvas Container Wrapper -->
<div class="relative w-full h-full overflow-hidden z-0">
  
  <!-- Map Canvas Container -->
  <div id="weather_map_container"
       data-controller="weather-map"
       data-weather-map-lat-value="<%= @latitude %>"
       data-weather-map-lon-value="<%= @longitude %>"
       data-weather-map-name-value="<%= @location_name %>"
       data-weather-map-temp-value="<%= current["temperature_2m"].round %>"
       data-weather-map-desc-value="<%= current_info[:description] %>"
       data-weather-map-time-value="<%= @local_time.strftime("%A, %b %-d, %I:%M %p") %><%= @weather["timezone_abbreviation"] ? " #{@weather["timezone_abbreviation"]}" : "" %>"
       data-weather-map-icon-value="<%= current_info[:icon] %>"
       data-weather-map-unit-symbol-value="<%= unit_system == 'imperial' ? '°F' : '°C' %>"
       class="w-full h-full z-0 relative">
    
    <!-- Map Canvas Target -->
    <div data-weather-map-target="canvas" class="w-full h-full z-0 relative"></div>
  </div>

  <!-- Floating Geolocation Button on the map (outside permanent container to always render) -->
  <button type="button"
          data-controller="map-locate"
          data-action="click->map-locate#locateUser"
          class="absolute bottom-24 right-3.5 z-[1000] p-3 rounded-full bg-white/90 dark:bg-slate-900/90 border border-slate-200 dark:border-slate-800/80 text-slate-700 dark:text-slate-300 hover:text-cyan-600 dark:hover:text-cyan-400 shadow-md hover:shadow-lg transition cursor-pointer flex items-center justify-center"
          title="Use current location">
    <i data-lucide="locate" class="w-5 h-5"></i>
  </button>
</div>
